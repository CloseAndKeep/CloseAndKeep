NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public site URL used for sitemap, robots.txt, and Open Graph absolute links (no trailing slash).
# On Vercel production, set this to your canonical domain (e.g. https://closeandkeep.com).
# NEXT_PUBLIC_SITE_URL=https://closeandkeep.com

# Production on Vercel: set to your FastAPI public origin (no trailing slash). Enables same-origin
# /__cak_api proxy so the browser does not need NEXT_PUBLIC_API_BASE_URL or CORS for the web domain.
# BACKEND_URL=https://api.yourdomain.com
