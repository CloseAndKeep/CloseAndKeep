APP_NAME=CloseAndKeep API
APP_ENV=development
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=closeandkeep_session
SESSION_COOKIE_SECURE=false
# Set true behind Render/Vercel/nginx that overwrite X-Forwarded-For.
TRUST_PROXY=false
SESSION_TTL_HOURS=24
SESSION_REFRESH_THRESHOLD_MINUTES=60
# Comma-separated emails that should be granted the admin role on signup/login.
ADMIN_EMAILS=founder@example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Auth rate limits (login / signup / guest)
# RATE_LIMIT_AUTH_IP=30
# RATE_LIMIT_AUTH_IP_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_EMAIL=10
# RATE_LIMIT_AUTH_EMAIL_WINDOW_SECONDS=60
# Replace re_xxxxxxxxx with your real key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
# Resend test sender (fine for internal order alerts). Use your domain later for customer-facing mail.
RESEND_FROM=onboarding@resend.dev
# Inbox that receives a copy of every new order (plain + HTML body with full details).
ORDER_NOTIFICATION_TO=closeandkeep@gmail.com
# LIVE MODE = real money. Use keys from Stripe with the "Test mode" toggle OFF.
# Live secret keys start with sk_live_ (test keys start with sk_test_).
STRIPE_SECRET_KEY=sk_live_xxx
# Live webhook signing secret: create the endpoint in the LIVE dashboard
# (Developers → Webhooks) and copy its whsec_ value. Test/live secrets differ.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# One-time $1 price created in LIVE mode (Product catalog → one-time Price → $1.00).
# Live price IDs are distinct from test price IDs. Used for all cookie pack sizes.
STRIPE_PRICE_ID=price_xxx
# Optional per-pack overrides if you add separate LIVE prices later:
# STRIPE_PRICE_COOKIES_1=price_xxx
# STRIPE_PRICE_COOKIES_4=price_xxx
# STRIPE_PRICE_COOKIES_12=price_xxx
